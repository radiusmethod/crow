      "Bash(ride list-worktrees:*)",
      "Bash(ride new-terminal:*)",
      "Bash(ride list-terminals:*)",
      "Bash(ride send:*)",
      "Bash(ride add-link:*)",
      "Bash(ride list-links:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
