      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(which:*)",
      "Bash(which -a:*)",
      "Bash(sleep:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
